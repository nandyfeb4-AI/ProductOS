# Backend
ENVIRONMENT=development
API_V1_PREFIX=/api
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_APP_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql+psycopg://postgres:postgres@localhost:54322/postgres

# Optional LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Jira
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8001/api/connectors/jira/callback
JIRA_SCOPES=offline_access read:me read:jira-user read:jira-work write:jira-work

# Mural
MURAL_CLIENT_ID=
MURAL_CLIENT_SECRET=
MURAL_REDIRECT_URI=http://localhost:8000/api/connectors/mural/callback
MURAL_SCOPES=identity:read workspaces:read rooms:read murals:read
